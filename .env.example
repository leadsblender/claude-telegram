# ── Required ──────────────────────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Your Telegram user ID (get it from @userinfobot)
# Multiple users: comma-separated, e.g. 123456789,987654321
ALLOWED_USER_IDS=

# ── Portal (optional) ─────────────────────────────────────────────────────────
# Connect to a LeadsBlender Client Portal to execute pending tasks
# Get these from your portal under Settings → AI Medewerker
PORTAL_URL=
PORTAL_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Directory Claude works from (defaults to current directory)
WORK_DIR=

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-6

# Max time (ms) to wait for Claude response (default: 120000 = 2 min)
TIMEOUT_MS=120000

# Claude tools to allow (comma-separated)
ALLOWED_TOOLS=Bash,Read,Write,Edit,Glob,Grep,WebFetch,WebSearch
